{
  "pipelines": [
    {
      "name": "parse_verify",
      "description": "Parse and verify MLIR Core profile inputs.",
      "args": []
    },
    {
      "name": "canonicalize",
      "description": "Run canonicalization for scalar/vector/kernel-like IR.",
      "args": ["--canonicalize"]
    },
    {
